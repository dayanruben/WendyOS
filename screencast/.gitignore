# Dependencies and local Slidev outputs
node_modules/
.slidev/
dist/

# Generated or captured media embedded by the deck
deck/public/videos/*
!deck/public/videos/.gitkeep
deck/public/images/*
!deck/public/images/.gitkeep

# Generated voiceover audio
voiceover/mp3/*
!voiceover/mp3/.gitkeep

# Final renders and temporary build outputs
output/*
!output/.gitkeep
build/

# Local bytecode and OS metadata
__pycache__/
*.pyc
.DS_Store
