# Required for scripts/render-voice.
# Use a restricted OpenAI key for text-to-speech if your account supports scoped keys.
# Do not put a real key in committed files.
OPENAI_API_KEY=

# Optional TTS overrides.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_ALLOWED_MODELS=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.25

# Optional render overrides.
SCREENCAST_WIDTH=1440
SCREENCAST_HEIGHT=900
SCREENCAST_FPS=10
