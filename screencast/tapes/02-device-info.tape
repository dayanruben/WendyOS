Output deck/public/videos/mac-beta/02-device-info.mp4
Set Shell zsh
Set Width 1440
Set Height 900
Set FontSize 20
Set FontFamily "JetBrains Mono, JetBrainsMono, JetBrainsMono Nerd Font, JetBrainsMono Nerd Font Mono, monospace"
Set Framerate 10
Set CursorBlink false


Sleep 1s

Type "wendy --device mac-mini.local:50051 device info --json"
Enter
Sleep 8s
