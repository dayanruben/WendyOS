FROM itzg/minecraft-server:latest

ARG EULA=TRUE
ARG TYPE=PAPER
ARG VERSION=LATEST
ARG MEMORY=4G
ARG MAX_PLAYERS=10
ARG MOTD="WendyMC — hosted by Wendy"
ARG ONLINE_MODE=TRUE
ARG ENABLE_RCON=true
ARG RCON_PASSWORD=wendymc-local
ARG RCON_PORT=25575
ARG SERVER_PORT=25565

ENV EULA=${EULA} \
    TYPE=${TYPE} \
    VERSION=${VERSION} \
    MEMORY=${MEMORY} \
    MAX_PLAYERS=${MAX_PLAYERS} \
    MOTD=${MOTD} \
    ONLINE_MODE=${ONLINE_MODE} \
    ENABLE_RCON=${ENABLE_RCON} \
    RCON_PASSWORD=${RCON_PASSWORD} \
    RCON_PORT=${RCON_PORT} \
    SERVER_PORT=${SERVER_PORT}
