{
  "appId": "sh.wendy.examples.claude-on-device",
  "version": "1.0.0",
  "platform": "linux",
  "entitlements": [
    {
      "type": "admin"
    },
    {
      "type": "persist",
      "name": "home",
      "path": "/root"
    },
    {
      "type": "persist",
      "name": "workspace",
      "path": "/workspace"
    },
    {
      "type": "network"
    }
  ]
}
