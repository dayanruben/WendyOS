{
    "appId": "sh.wendy.examples.hellomesh",
    "platform": "linux",
    "version": "1.0.0",
    "isolation": "isolated",
    "services": {
        "node": {
            "context": "./client",
            "entitlements": [
                {
                    "type": "network",
                    "mode": "mesh",
                    "serviceCIDR": "10.99.0.0/16",
                    "ports": [
                        { "host": 8080, "container": 8080 }
                    ]
                }
            ]
        }
    }
}
